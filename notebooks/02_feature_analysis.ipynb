{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 02 — Feature Analysis\n",
    "\n",
    "**Purpose:** Inspect the built feature matrix — distributions, correlations, and naive predictive power of individual features.\n",
    "\n",
    "**Snooping warning:** Looking at feature-target correlations on the full dataset tells you how predictive features were *in the past* but doesn't mean they'll work going forward. Use this for sanity-checking and debugging, not for selecting features."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import plotly.express as px\n",
    "\n",
    "%matplotlib inline"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load the pre-built feature matrix (run the pipeline first)\n",
    "try:\n",
    "    from src.features.build import load_feature_matrix\n",
    "    features = load_feature_matrix()\n",
    "    print(f\"Loaded feature matrix: {features.shape}\")\n",
    "    print(f\"Tickers: {features['ticker'].nunique()}\")\n",
    "    print(f\"Date range: {features['date'].min().date()} to {features['date'].max().date()}\")\n",
    "    features.head()\n",
    "except FileNotFoundError:\n",
    "    print(\"Feature matrix not found. Build it first:\")\n",
    "    print(\"  python scripts/run_full_pipeline.py\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.features.build import get_feature_columns\n",
    "feat_cols = get_feature_columns(features)\n",
    "print(f\"{len(feat_cols)} feature columns:\")\n",
    "for c in feat_cols:\n",
    "    print(f\"  {c}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Target class balance\n",
    "balance = features['target_binary'].value_counts(normalize=True)\n",
    "print(f\"Target class balance:\")\n",
    "print(f\"  Up (1):   {balance.get(1, 0):.1%}\")\n",
    "print(f\"  Down (0): {balance.get(0, 0):.1%}\")\n",
    "\n",
    "# Note: close to 50/50 is expected and healthy for a binary classifier"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Feature descriptive stats\n",
    "features[feat_cols].describe().round(4)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Point-biserial correlations with the binary target\n",
    "# Caveat: this uses the FULL dataset — snooping territory. Use for debugging only.\n",
    "from scipy import stats\n",
    "\n",
    "corrs = {}\n",
    "for col in feat_cols:\n",
    "    r, p = stats.pointbiserialr(\n",
    "        features['target_binary'],\n",
    "        features[col].fillna(0),\n",
    "    )\n",
    "    corrs[col] = {'correlation': r, 'p_value': p}\n",
    "\n",
    "corr_df = pd.DataFrame(corrs).T.sort_values('correlation', key=abs, ascending=False)\n",
    "print(\"Top 10 features by absolute correlation with target:\")\n",
    "corr_df.head(10).round(4)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Feature correlation matrix (features against each other)\n",
    "corr_matrix = features[feat_cols].corr()\n",
    "\n",
    "# Flag highly correlated feature pairs (potential redundancy)\n",
    "threshold = 0.85\n",
    "high_corr_pairs = []\n",
    "for i, c1 in enumerate(feat_cols):\n",
    "    for c2 in feat_cols[i+1:]:\n",
    "        val = corr_matrix.loc[c1, c2]\n",
    "        if abs(val) > threshold:\n",
    "            high_corr_pairs.append((c1, c2, val))\n",
    "\n",
    "if high_corr_pairs:\n",
    "    print(f\"Highly correlated feature pairs (|r| > {threshold}):\")\n",
    "    for c1, c2, v in high_corr_pairs:\n",
    "        print(f\"  {c1:30s} <-> {c2:30s}: {v:.3f}\")\n",
    "else:\n",
    "    print(f\"No feature pairs with |r| > {threshold}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualise feature distributions split by target\n",
    "top_features = corr_df.head(4).index.tolist()\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(12, 8))\n",
    "for ax, feat in zip(axes.flat, top_features):\n",
    "    up = features.loc[features['target_binary'] == 1, feat].dropna()\n",
    "    down = features.loc[features['target_binary'] == 0, feat].dropna()\n",
    "    q01, q99 = features[feat].quantile([0.01, 0.99])\n",
    "    up_clipped = up.clip(q01, q99)\n",
    "    down_clipped = down.clip(q01, q99)\n",
    "    ax.hist(down_clipped, bins=60, alpha=0.5, label='Down (0)', color='#DC2626', density=True)\n",
    "    ax.hist(up_clipped, bins=60, alpha=0.5, label='Up (1)', color='#16A34A', density=True)\n",
    "    ax.set_title(feat)\n",
    "    ax.legend(fontsize=8)\n",
    "\n",
    "plt.suptitle('Feature Distributions by Target Class', fontsize=13)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
 ],
